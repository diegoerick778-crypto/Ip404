import requests
import os
import webbrowser
import ipaddress
import time
from datetime import datetime

# ===== CORES =====
vermelho = "\033[91m"
verde = "\033[92m"
azul = "\033[94m"
amarelo = "\033[93m"
roxo = "\033[95m"
cyan = "\033[96m"
reset = "\033[0m"

# ===== LIMPAR =====
os.system("cls" if os.name == "nt" else "clear")

# ===== BANNER =====
banner = f"""{vermelho}

██╗██████╗     ████████╗██████╗  █████╗  ██████╗██╗  ██╗███████╗██████╗ 
██║██╔══██╗    ╚══██╔══╝██╔══██╗██╔══██╗██╔════╝██║ ██╔╝██╔════╝██╔══██╗
██║██████╔╝       ██║   ██████╔╝███████║██║     █████╔╝ █████╗  ██████╔╝
██║██╔═══╝        ██║   ██╔══██╗██╔══██║██║     ██╔═██╗ ██╔══╝  ██╔══██╗
██║██║            ██║   ██║  ██║██║  ██║╚██████╗██║  ██╗███████╗██║  ██║
╚═╝╚═╝            ╚═╝   ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝

                by Erick.zz76
{reset}
"""

# ===== ANIMAÇÃO =====
for letra in banner:
    print(letra, end="", flush=True)
    time.sleep(0.0005)

# ===== LOADING =====
print(cyan + "\nInicializando sistema..." + reset)

for i in range(0, 101, 10):
    barra = "■" * (i // 10) + "□" * (10 - (i // 10))
    print(f"\r[{barra}] {i}%", end="")
    time.sleep(0.08)

print("\n")

# ===== SALVAR LOG =====
def salvar_log(texto):
    with open("logs.txt", "a", encoding="utf-8") as f:
        f.write(texto + "\n")

# ===== MAPS =====
def abrir_maps(lat, lon):
    url = f"https://www.google.com/maps?q={lat},{lon}"

    print(verde + "\nAbrindo Google Maps..." + reset)

    try:
        if os.name == "posix":
            os.system(f'am start -a android.intent.action.VIEW -d "{url}"')
        else:
            webbrowser.open(url)
    except:
        webbrowser.open(url)

# ===== LOCALIZAR IP =====
def localizar_ip():
    ip = input(cyan + "\nDigite o IP: " + reset)

    try:
        ip_obj = ipaddress.ip_address(ip)

        if ip_obj.is_private:
            print(vermelho + "\n[!] IP privado detectado." + reset)
            return

    except ValueError:
        print(vermelho + "\n[!] IP inválido." + reset)
        return

    print(amarelo + "\nBuscando informações..." + reset)

    try:
        resposta = requests.get(
            f"http://ip-api.com/json/{ip}",
            timeout=5
        )

        dados = resposta.json()

    except:
        print(vermelho + "\n[!] Erro de conexão." + reset)
        return

    if dados["status"] != "success":
        print(vermelho + "\n[!] Não foi possível localizar." + reset)
        return

    # ===== DADOS =====
    pais = dados.get("country")
    cidade = dados.get("city")
    regiao = dados.get("regionName")
    org = dados.get("org")
    asn = dados.get("as")
    lat = dados.get("lat")
    lon = dados.get("lon")
    timezone = dados.get("timezone")
    isp = dados.get("isp")

    print(verde + "\n===== RESULTADO =====" + reset)

    print(f"""
{roxo}IP:{reset} {ip}
{roxo}País:{reset} {pais}
{roxo}Cidade:{reset} {cidade}
{roxo}Região:{reset} {regiao}
{roxo}Provedor:{reset} {isp}
{roxo}Organização:{reset} {org}
{roxo}ASN:{reset} {asn}
{roxo}Timezone:{reset} {timezone}
{roxo}Latitude:{reset} {lat}
{roxo}Longitude:{reset} {lon}
""")

    horario = datetime.now().strftime("%d/%m/%Y %H:%M:%S")

    salvar_log(
        f"[{horario}] IP: {ip} | {cidade} - {pais}"
    )

    escolha = input(
        cyan + "Abrir localização no Maps? (y/n): " + reset
    ).lower()

    if escolha == "y":
        abrir_maps(lat, lon)

# ===== LOCALIZAR CEP =====
def localizar_cep():
    cep = input(cyan + "\nDigite o CEP: " + reset)

    cep = cep.replace("-", "").replace(".", "")

    if len(cep) != 8 or not cep.isdigit():
        print(vermelho + "\n[!] CEP inválido." + reset)
        return

    print(amarelo + "\nConsultando CEP..." + reset)

    try:
        resposta = requests.get(
            f"https://viacep.com.br/ws/{cep}/json/",
            timeout=5
        )

        dados = resposta.json()

    except:
        print(vermelho + "\n[!] Erro de conexão." + reset)
        return

    if "erro" in dados:
        print(vermelho + "\n[!] CEP não encontrado." + reset)
        return

    rua = dados.get("logradouro")
    bairro = dados.get("bairro")
    cidade = dados.get("localidade")
    estado = dados.get("uf")

    print(verde + "\n===== RESULTADO =====" + reset)

    print(f"""
{roxo}CEP:{reset} {dados.get("cep")}
{roxo}Rua:{reset} {rua}
{roxo}Bairro:{reset} {bairro}
{roxo}Cidade:{reset} {cidade}
{roxo}Estado:{reset} {estado}
""")

    endereco = f"{rua}, {bairro}, {cidade}, {estado}"
    url = f"https://www.google.com/maps/search/{endereco.replace(' ', '+')}"

    escolha = input(
        cyan + "Abrir endereço no Maps? (y/n): " + reset
    ).lower()

    if escolha == "y":

        try:
            if os.name == "posix":
                os.system(
                    f'am start -a android.intent.action.VIEW -d "{url}"'
                )
            else:
                webbrowser.open(url)

        except:
            webbrowser.open(url)

# ===== MENU =====
def menu():

    while True:

        print(azul + """
╔════════════════════════╗
║       MENU             ║
╠════════════════════════╣
║ [1] Localizar IP       ║
║ [2] Localizar CEP      ║
║ [0] Sair               ║
╚════════════════════════╝
""" + reset)

        escolha = input(cyan + "Escolha: " + reset)

        if escolha == "1":
            localizar_ip()

        elif escolha == "2":
            localizar_cep()

        elif escolha == "0":
            print(verde + "\nFinalizando sistema..." + reset)
            break

        else:
            print(vermelho + "\n[!] Opção inválida." + reset)

# ===== START =====
if __name__ == "__main__":
    menu()
