import requests
import os
import webbrowser
import ipaddress
import time
import shutil
import subprocess
from datetime import datetime

# ===== CORES =====
class C:
    RED = "\033[91m"
    GREEN = "\033[92m"
    BLUE = "\033[94m"
    YELLOW = "\033[93m"
    PURPLE = "\033[95m"
    CYAN = "\033[96m"
    WHITE = "\033[97m"
    RESET = "\033[0m"

# ===== CLEAR =====
def clear():
    os.system("cls" if os.name == "nt" else "clear")

# ===== BANNER =====
def banner():

    clear()

    texto = f"""{C.RED}

в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ       в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ        в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘            в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
в•ҡв•җв•қв•ҡв•җв•қ            в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ

               IP TRACKER X - V3
                   Erick.zz76
{C.RESET}
"""

    for letra in texto:
        print(letra, end="", flush=True)
        time.sleep(0.0003)

# ===== LOADING =====
def loading(msg="Inicializando"):

    print(C.CYAN + f"\n{msg}..." + C.RESET)

    for i in range(0, 101, 10):
        barra = "в– " * (i // 10) + "в–Ў" * (10 - (i // 10))
        print(f"\r[{barra}] {i}%", end="")
        time.sleep(0.05)

    print("\n")

# ===== LOG =====
def salvar_log(texto):

    with open("logs.txt", "a", encoding="utf-8") as f:
        f.write(texto + "\n")

# ===== MAPS =====
def abrir_maps(lat, lon):

    url = f"https://www.google.com/maps?q={lat},{lon}"

    print(C.GREEN + "\nAbrindo Google Maps..." + C.RESET)

    try:
        if os.name == "posix":
            os.system(f'am start -a android.intent.action.VIEW -d "{url}"')
        else:
            webbrowser.open(url)

    except:
        webbrowser.open(url)

# ===== GEO IP =====
def localizar_ip():

    ip = input(C.CYAN + "\nDigite o IP: " + C.RESET)

    try:
        ip_obj = ipaddress.ip_address(ip)

        if ip_obj.is_private:
            print(C.RED + "\n[!] IP privado detectado." + C.RESET)
            return

    except ValueError:
        print(C.RED + "\n[!] IP invГЎlido." + C.RESET)
        return

    print(C.YELLOW + "\nBuscando informaГ§Гөes..." + C.RESET)

    try:
        resposta = requests.get(
            f"http://ip-api.com/json/{ip}",
            timeout=5
        )

        dados = resposta.json()

    except:
        print(C.RED + "\n[!] Erro de conexГЈo." + C.RESET)
        return

    if dados.get("status") != "success":
        print(C.RED + "\n[!] NГЈo foi possГӯvel localizar." + C.RESET)
        return

    print(C.GREEN + "\n===== RESULTADO =====" + C.RESET)

    print(f"""
{C.PURPLE}IP:{C.RESET} {ip}
{C.PURPLE}PaГӯs:{C.RESET} {dados.get('country')}
{C.PURPLE}Cidade:{C.RESET} {dados.get('city')}
{C.PURPLE}RegiГЈo:{C.RESET} {dados.get('regionName')}
{C.PURPLE}ISP:{C.RESET} {dados.get('isp')}
{C.PURPLE}ASN:{C.RESET} {dados.get('as')}
{C.PURPLE}Timezone:{C.RESET} {dados.get('timezone')}
{C.PURPLE}Latitude:{C.RESET} {dados.get('lat')}
{C.PURPLE}Longitude:{C.RESET} {dados.get('lon')}
{C.PURPLE}Mobile:{C.RESET} {dados.get('mobile')}
{C.PURPLE}Proxy/VPN:{C.RESET} {dados.get('proxy')}
""")

    horario = datetime.now().strftime("%d/%m/%Y %H:%M:%S")

    salvar_log(
        f"[{horario}] IP: {ip} | {dados.get('city')} - {dados.get('country')}"
    )

    escolha = input(
        C.CYAN + "Abrir localizaГ§ГЈo no Maps? (y/n): " + C.RESET
    ).lower()

    if escolha == "y":
        abrir_maps(dados.get("lat"), dados.get("lon"))

# ===== CEP =====
def localizar_cep():

    cep = input(C.CYAN + "\nDigite o CEP: " + C.RESET)

    cep = cep.replace("-", "").replace(".", "")

    if len(cep) != 8 or not cep.isdigit():
        print(C.RED + "\n[!] CEP invГЎlido." + C.RESET)
        return

    print(C.YELLOW + "\nConsultando CEP..." + C.RESET)

    try:
        resposta = requests.get(
            f"https://viacep.com.br/ws/{cep}/json/",
            timeout=5
        )

        dados = resposta.json()

    except:
        print(C.RED + "\n[!] Erro de conexГЈo." + C.RESET)
        return

    if "erro" in dados:
        print(C.RED + "\n[!] CEP nГЈo encontrado." + C.RESET)
        return

    print(C.GREEN + "\n===== RESULTADO =====" + C.RESET)

    print(f"""
{C.PURPLE}CEP:{C.RESET} {dados.get('cep')}
{C.PURPLE}Rua:{C.RESET} {dados.get('logradouro')}
{C.PURPLE}Bairro:{C.RESET} {dados.get('bairro')}
{C.PURPLE}Cidade:{C.RESET} {dados.get('localidade')}
{C.PURPLE}Estado:{C.RESET} {dados.get('uf')}
""")

# ===== NMAP =====
def scanner_portas():

    if not shutil.which("nmap"):
        print(C.RED + "\n[!] Nmap nГЈo instalado." + C.RESET)
        print(C.YELLOW + "Instale com:" + C.RESET)
        print("pkg install nmap")
        return

    alvo = input(C.CYAN + "\nIP ou host alvo: " + C.RESET)

    print(C.YELLOW + "\nExecutando scanner..." + C.RESET)

    try:
        comando = [
            "nmap",
            "-F",   # scan rГЎpido
            alvo
        ]

        resultado = subprocess.run(
            comando,
            capture_output=True,
            text=True
        )

        print(C.GREEN + "\n===== RESULTADO NMAP =====\n" + C.RESET)
        print(resultado.stdout)

        horario = datetime.now().strftime("%d/%m/%Y %H:%M:%S")

        salvar_log(
            f"[{horario}] NMAP executado em: {alvo}"
        )

    except Exception as e:
        print(C.RED + f"\n[!] Erro: {e}" + C.RESET)

# ===== LOGS =====
def ver_logs():

    if not os.path.exists("logs.txt"):
        print(C.RED + "\n[!] Nenhum log encontrado." + C.RESET)
        return

    print(C.GREEN + "\n===== LOGS =====\n" + C.RESET)

    with open("logs.txt", "r", encoding="utf-8") as f:
        print(f.read())

# ===== MENU =====
def menu():

    while True:

        print(C.BLUE + """
в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
в•‘         MENU V3           в•‘
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘ [1] Localizar IP          в•‘
в•‘ [2] Localizar CEP         в•‘
в•‘ [3] Scanner Nmap          в•‘
в•‘ [4] Ver logs              в•‘
в•‘ [0] Sair                  в•‘
в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ
""" + C.RESET)

        escolha = input(C.CYAN + "Escolha: " + C.RESET)

        if escolha == "1":
            localizar_ip()

        elif escolha == "2":
            localizar_cep()

        elif escolha == "3":
            scanner_portas()

        elif escolha == "4":
            ver_logs()

        elif escolha == "0":
            print(C.GREEN + "\nFinalizando sistema..." + C.RESET)
            break

        else:
            print(C.RED + "\n[!] OpГ§ГЈo invГЎlida." + C.RESET)

# ===== START =====
if __name__ == "__main__":

    banner()
    loading()
    menu()
